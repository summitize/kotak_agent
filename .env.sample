# Kotak Neo API v2 Credentials
KOTAK_ACCESS_TOKEN=your_neo_dashboard_access_token_here
KOTAK_MOBILE_NUMBER=+91XXXXXXXXXX
KOTAK_UCC=your_client_code_here
KOTAK_MPIN=your_6_digit_mpin_here

# Provide EITHER the dynamic 6-digit TOTP token OR the 16/32-character TOTP secret key.
# If KOTAK_TOTP_TOKEN is provided, it will be used directly.
# If KOTAK_TOTP_TOKEN is empty and KOTAK_TOTP_SECRET is provided, the script will automatically generate the TOTP.
# If both are empty or missing, the program will terminate.
KOTAK_TOTP_TOKEN=
KOTAK_TOTP_SECRET=
